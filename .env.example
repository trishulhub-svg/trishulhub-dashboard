# ━━ Database (Prisma needs a file: URL for schema, adapter overrides at runtime) ━━
DATABASE_URL=file:./db/turso.db
DATABASE_DIRECT_URL=file:./db/turso.db

# ━━ Turso Connection (used by the libSQL adapter in db.ts) ━━
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ━━ NextAuth Configuration ━━
NEXTAUTH_URL=https://agent.trishulhub.in
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production

# ━━ AI API Keys ━━
ZAI_API_KEY=
OPENROUTER_API_KEY=
