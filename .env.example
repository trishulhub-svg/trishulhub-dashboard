# Database - SQLite file path (relative to project root)
DATABASE_URL=file:./db/custom.db

# NextAuth Configuration
# IMPORTANT: Set this to your actual domain URL (with https://)
# Examples:
#   - https://agent.trishulhub.in
#   - https://yourdomain.com
#   - http://localhost:3000 (for local development only)
NEXTAUTH_URL=https://agent.trishulhub.in
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production

# Server Configuration
HOSTNAME=0.0.0.0
PORT=3000
